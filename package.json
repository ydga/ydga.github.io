{
  "name": "starter-kit",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter \"@starter-kit/*\" build && pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter theme-engine test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  }
}
